<?xml version="1.0" encoding="UTF-8"?>
<odoo>

<data>

<!-- Insert categories ABOVE product grid -->

<template id="store_categories_block"
          inherit_id="website_sale.products"
          name="Store Categories Block">

    <xpath expr="//div[@id='products_grid']" position="inside">

        <!-- Fetch categories -->
        <t t-set="store_cats"
           t-value="request.env['product.public.category'].search([
                ('name', 'in', [
                    'Residential Doors',
                    'Commercial Doors'
                ])
           ])"/>

        <!-- Wrapper -->
        <div id="door_categories_block" class="container my-4">

            <div class="row door_categories_row">

                <t t-foreach="store_cats" t-as="cat">

                    <div class="col-lg-2 col-md-3 col-6 text-center door_category_card">

                        <a t-att-href="'/shop/category/%s' % cat.id"
                           class="door-category-link">

                            <img t-att-src="'/web/image/product.public.category/%s/image_1024' % cat.id"
                                 class="img-fluid category_image"/>

                            <div class="category_name mt-2">

                                <span t-esc="cat.name"/>

                            </div>

                        </a>

                    </div>

                </t>

            </div>

        </div>

    </xpath>

</template>

</data>

</odoo>